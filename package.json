{
  "name": "sawstop-finger-save",
  "private": true,
  "version": "0.0.0",
  "description": "Minimal local harness for SawStop Finger Save verification scripts.",
  "scripts": {
    "check:notion-schema": "node --experimental-strip-types scripts/check-notion-schema.ts",
    "check:allowed-values": "node --experimental-strip-types scripts/check-allowed-values.ts",
    "check:attachment-source-live": "node --experimental-strip-types scripts/check-attachment-source-live.ts",
    "check:fifo-trash-candidates": "node --experimental-strip-types scripts/check-fifo-trash-candidates.ts",
    "smoke:submit": "node --experimental-strip-types scripts/smoke-submit.ts",
    "smoke:admin-search": "node --experimental-strip-types scripts/smoke-admin-search.ts",
    "smoke:admin-upload": "node --experimental-strip-types scripts/smoke-admin-upload.ts",
    "smoke:admin-list-attachments": "node --experimental-strip-types scripts/smoke-admin-list-attachments.ts",
    "smoke:admin-move-attachment-to-trash": "node --experimental-strip-types scripts/smoke-admin-move-attachment-to-trash.ts",
    "smoke:admin-process-fifo-trash": "node --experimental-strip-types scripts/smoke-admin-process-fifo-trash.ts",
    "smoke:admin-restore-attachment": "node --experimental-strip-types scripts/smoke-admin-restore-attachment.ts",
    "smoke:admin-update-attachment-type": "node --experimental-strip-types scripts/smoke-admin-update-attachment-type.ts",
    "ci": "npm run test",
    "deploy:ci": "npx wrangler deploy",
    "dev:local": "npx wrangler dev",
    "dev:fully-local": "npx wrangler dev --local",
    "dev:remote": "npx wrangler dev --remote",
    "dev:recalculate-finger-photo": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/recalculate-finger-photo.ts",
    "test": "npm run check:notion-schema && npm run check:allowed-values && npm run smoke:submit && npm run smoke:admin-search && npm run smoke:admin-upload && npm run smoke:admin-list-attachments && npm run smoke:admin-update-attachment-type && npm run smoke:admin-move-attachment-to-trash && npm run smoke:admin-restore-attachment && npm run smoke:admin-process-fifo-trash",
    "lint": "node --check scripts/verify-gates.js",
    "verify:gates": "node scripts/verify-gates.js --status"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "wrangler": "^4.81.1"
  }
}
